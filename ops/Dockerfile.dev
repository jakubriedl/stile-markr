# syntax=docker/dockerfile:1.7
# Shared development image for Compose hot-reload (bind-mounted source).

FROM node:24.14.1-bookworm-slim
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate

COPY --from=oven/bun:1.3.11-slim /usr/local/bin/bun /usr/local/bin/bun

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY tsconfig.base.json ./
COPY backend/package.json backend/
COPY frontend/package.json frontend/

RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
  pnpm install --frozen-lockfile --filter @markr/backend... --filter @markr/frontend...

COPY backend ./backend
COPY frontend ./frontend
COPY ops/dev-entrypoint.sh ./ops/dev-entrypoint.sh

RUN chmod +x ./ops/dev-entrypoint.sh \
  && mkdir -p /data

ENV NODE_ENV=development \
  DATABASE_PATH=/data/markr.sqlite \
  HOST=0.0.0.0

ENTRYPOINT ["/app/ops/dev-entrypoint.sh"]
EXPOSE 3000 4567
